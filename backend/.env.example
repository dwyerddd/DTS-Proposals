# Copy this file to .env and fill in your real values.
# .env is git-ignored — never commit real credentials.

# Supabase connection string.
# Find it in Supabase: Project Settings -> Database -> Connection string -> URI
# (use the "Session pooler" or direct connection string, whichever you set up)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT_REF.supabase.co:5432/postgres
